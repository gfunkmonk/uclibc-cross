#!/bin/bash

set -e
set -o pipefail

TARGET=$1
TARGET_CFLAGS=""
TARGET_LDFLAGS=""
EXTRA_CT_NG_ARGS=""

if [[ $# -lt 1 || -z "$1" ]]; then
    echo "Usage: $0 <target>" >&2
    echo "Example: $0 x86_64-unknown-linux-uclibc" >&2
    exit 1
fi

TARGET=$1
if [[ ! -d "targets/${TARGET}" ]]; then
    echo "Error: target '${TARGET}' not found in targets/" >&2
    exit 1
fi

# Enable Kitware repo
CODENAME=$(lsb_release -cs 2>/dev/null || echo "noble")
if [ ! -f /usr/share/keyrings/kitware-archive-keyring.gpg ]; then
  wget -O - https://apt.kitware.com/keys/kitware-archive-latest.asc 2>/dev/null | \
    gpg --dearmor | \
    sudo tee /usr/share/keyrings/kitware-archive-keyring.gpg > /dev/null
fi

if [ ! -f /etc/apt/sources.list.d/kitware.list ]; then
  echo "deb [signed-by=/usr/share/keyrings/kitware-archive-keyring.gpg] https://apt.kitware.com/ubuntu/ ${CODENAME} main" | \
    sudo tee /etc/apt/sources.list.d/kitware.list > /dev/null
fi

# packages
sudo apt-get update -qy
sudo apt-get install -y --no-install-recommends \
  automake bison bzip2 ca-certificates cmake \
  curl file flex g++ gawk gdb git gperf help2man \
  libncurses-dev libssl-dev libtool-bin make patch \
  pkg-config python3 rsync texinfo unzip wget xz-utils \
  libzstd-dev

# Add newline to patches without one
find targets/ -name "*.patch" | while read -r f; do
    if [[ $(tail -c1 "$f" | wc -l) -eq 0 ]]; then
        echo "" >> "$f"
        echo "Fixed: $f"
    fi
done
# patch
pushd builder
git reset --hard HEAD
git clean -fd
shopt -s nullglob
for i in ../targets/"${TARGET}"/*.patch; do
    if grep -qE "^\+\+\+ b/packages/" "$i"; then
        # Wrapped package patch — apply it to create the patch file in place
        patch -Np1 -i "$i"
    elif grep -qE "^\+\+\+ b/(libc|ldso|extra)/" "$i"; then
        # Raw/unwrapped package patch — copy directly for ct-ng to consume
        mkdir -p "packages/uClibc-ng/1.0.57"
        cp "$i" "packages/uClibc-ng/1.0.57/$(basename "$i")"
    else
        # ct-ng core patch (scripts/build/arch etc.)
        patch -Np1 -i "$i"
    fi
done
shopt -u nullglob
popd

# crosstool-ng
sudo mkdir -p /opt
sudo chmod 0777 /opt
sudo rm -rf /opt/ct-ng
pushd builder
./bootstrap
./configure --prefix=/opt/ct-ng
make -j"$(nproc)"
sudo make install
popd

# build
rm -rf build
mkdir -p build
cp targets/"${TARGET}"/config build/.config

if [[ -f "targets/${TARGET}/uClibc-ng.config" ]]; then
    UCLIBC_CFG_ABS="$(realpath build)/uClibc-ng.config"
    cp "targets/${TARGET}/uClibc-ng.config" "build/uClibc-ng.config"
    sed -i "s|CT_LIBC_UCLIBC_CONFIG_FILE=.*|CT_LIBC_UCLIBC_CONFIG_FILE=\"${UCLIBC_CFG_ABS}\"|" build/.config
    echo "Copied uClibc-ng.config for ${TARGET} -> ${UCLIBC_CFG_ABS}"
fi

# Configure tarballs directory for download caching
#echo 'CT_LOCAL_TARBALLS_DIR="/mnt/tarballs"' >> build/.config
#echo 'CT_SAVE_TARBALLS=y' >> build/.config

if [[ -n "${TARGET_CFLAGS}" ]]; then
    echo "CT_TARGET_CFLAGS=\"${TARGET_CFLAGS}\"" >> build/.config
fi
if [[ -n "${TARGET_LDFLAGS}" ]]; then
    echo "CT_TARGET_LDFLAGS=\"${TARGET_LDFLAGS}\"" >> build/.config
fi

pushd build
/opt/ct-ng/bin/ct-ng olddefconfig
/opt/ct-ng/bin/ct-ng build."$(nproc)" ${EXTRA_CT_NG_ARGS}
popd

# tarball
sudo mv /opt/x-tools/"${TARGET}" .
sudo chown -R root:root "${TARGET}"
env XZ_OPT="-T0" sudo tar -cJvf "${TARGET}".tar.xz "${TARGET}"
sudo sha256sum "${TARGET}".tar.xz | awk '{ print $1 }' > "${TARGET}".tar.xz.sha256
