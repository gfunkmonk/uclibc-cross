#!/bin/bash

set -e
set -o pipefail

if [[ $# -lt 1 || -z "$1" ]]; then
    echo "Usage: $0 <target>" >&2
    echo "Example: $0 x86_64-unknown-linux-uclibc" >&2
    exit 1
fi
TARGET=$1
if [[ ! -d "targets/${TARGET}" ]]; then
    echo "Error: target '${TARGET}' not found in targets/" >&2
    exit 1
fi

# packages
sudo apt-get update
sudo apt-get install -y --no-install-recommends \
  automake \
  bison \
  bzip2 \
  ca-certificates \
  cmake \
  curl \
  file \
  flex \
  g++ \
  gawk \
  gdb \
  git \
  gperf \
  help2man \
  libncurses-dev \
  libssl-dev \
  libtool-bin \
  make \
  patch \
  pkg-config \
  python3 \
  rsync \
  texinfo \
  unzip \
  wget \
  xz-utils \
  libzstd-dev

# patch
pushd builder
git reset --hard HEAD
git clean -fd
#shopt -s nullglob
#for i in ../targets/"${TARGET}"/*.patch; do
#    patch -Np1 -i "$i"
#done
#shopt -u nullglob
# 5. Automated Patch Injection
# Logic to dynamically place patches where ct-ng expects them
for patch_file in ../"${TARGET_DIR}"/*.patch; do
    if [ -f "$patch_file" ]; then
        # Extract PKG and VER from the patch content or filename
        # This assumes your patches contain the standard path header
        PKG_NAME=$(grep -m 1 "+++ b/packages/" "$patch_file" | awk -F'/' '{print $3}')
        PKG_VER=$(grep -m 1 "+++ b/packages/" "$patch_file" | awk -F'/' '{print $4}')
        
        if [ -n "$PKG_NAME" ] && [ -n "$PKG_VER" ]; then
            DEST="packages/${PKG_NAME}/${PKG_VER}"
            mkdir -p "$DEST"
            cp "$patch_file" "$DEST/"
            echo "Successfully injected patch into $DEST"
        fi
    fi
done
cd ..
popd

# crosstool-ng
sudo mkdir -p /opt
sudo chmod 0777 /opt
sudo rm -rf /opt/ct-ng
pushd builder
./bootstrap
./configure --prefix=/opt/ct-ng
make -j"$(nproc)"
sudo make install
popd

# In scripts/make, before the build command
if [ "${TARGET}" = "sparc64-unknown-linux-uclibc" ]; then
    export ARCH="sparc64"
    # Use TARGET_CFLAGS/LDFLAGS or pass via ct-ng instead of global ASFLAGS
    # This prevents leaking '-64' into host-gcc calls
    EXTRA_CT_NG_ARGS="CT_TARGET_ASFLAGS=-64"
else
    UCLIBC_ARCH=$(echo "${TARGET}" | cut -d- -f1 | sed -E 's/(64|le|be)//g')
    echo "Force-setting ARCH=${UCLIBC_ARCH} for uClibc-ng safety"
    # Export these variables so the sub-make doesn't default to x86_64
    export ARCH="${UCLIBC_ARCH}"
    EXTRA_CT_NG_ARGS=""
fi
export CROSS_COMPILE="${TARGET}-"

# build
rm -rf build
mkdir -p build
cp targets/"${TARGET}"/config build/.config
# Configure tarballs directory for download caching
echo 'CT_LOCAL_TARBALLS_DIR="/mnt/tarballs"' >> build/.config
echo 'CT_SAVE_TARBALLS=y' >> build/.config
pushd build
/opt/ct-ng/bin/ct-ng olddefconfig
/opt/ct-ng/bin/ct-ng build."$(nproc)" ${EXTRA_CT_NG_ARGS}
popd

# tarball
# ct-ng may normalize the target triple (e.g. uclibceabi -> uclibcgnueabi),
# so read the actual CT_TARGET from the build config instead of using $TARGET
CT_ACTUAL=$(sed -n 's/^CT_TARGET="\(.*\)"/\1/p' build/.config)
rm -rf "${TARGET}"
sudo mv -T /opt/x-tools/${CT_ACTUAL} "${TARGET}"
#sudo mv /opt/x-tools/"${TARGET}" .
sudo chown -R root:root "${TARGET}"
env XZ_OPT="-T0" sudo tar -cJvf "${TARGET}".tar.xz "${TARGET}"
sudo sha256sum "${TARGET}".tar.xz | awk '{ print $1 }' > "${TARGET}".tar.xz.sha256
