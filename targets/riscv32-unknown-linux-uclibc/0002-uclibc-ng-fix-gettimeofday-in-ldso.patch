--- /dev/null
+++ b/packages/uClibc-ng/1.0.57/0002-fix-gettimeofday-in-ldso.patch
@@ -0,0 +1,33 @@
+ldso: guard _dl_gettimeofday with __NR_gettimeofday check
+
+Some architectures (such as riscv32) do not define __NR_gettimeofday
+in their Linux headers. Guard the syscall definition with an #ifdef
+and provide a fallback stub that returns -1 for the stack-protector
+canary initialization path.
+
+--- a/ldso/include/dl-syscall.h
++++ b/ldso/include/dl-syscall.h
+@@ -263,10 +263,14 @@
+ #ifdef __UCLIBC_HAS_SSP__
+ # include <sys/time.h>
+-# define __NR__dl_gettimeofday __NR_gettimeofday
+-static __always_inline _syscall2(int, _dl_gettimeofday, struct timeval *, tv,
+-# ifdef __USE_BSD
+-                        struct timezone *
+-# else
+-                        void *
+-# endif
+-						, tz)
++# ifdef __NR_gettimeofday
++#  define __NR__dl_gettimeofday __NR_gettimeofday
++static __always_inline _syscall2(int, _dl_gettimeofday, struct timeval *, tv,
++#  ifdef __USE_BSD
++                        struct timezone *
++#  else
++                        void *
++#  endif
++						, tz)
++# else
++static __always_inline int _dl_gettimeofday(struct timeval *tv, void *tz) { return -1; }
++# endif
+ #endif
