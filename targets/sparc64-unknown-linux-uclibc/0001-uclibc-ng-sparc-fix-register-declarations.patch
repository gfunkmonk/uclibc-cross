--- a/packages/uClibc-ng/1.0.57/0001-sparc-fix-register-declarations-in-clone.patch
+++ b/packages/uClibc-ng/1.0.57/0001-sparc-fix-register-declarations-in-clone.patch
@@ -0,0 +1,15 @@
+sparc: add .register pseudo-op declarations for global registers
+
+Newer binutils require .register directives when using global registers
+%g2 and %g3 in SPARC assembly. Add the declarations before the .text
+section to avoid "detected global register use not covered by .register"
+errors on sparc64.
+
+--- a/libc/sysdeps/linux/sparc/clone.S
++++ b/libc/sysdeps/linux/sparc/clone.S
+@@ -26,5 +26,8 @@
+ /* int clone(int (*fn)(void *arg), void *child_stack, int flags, void *arg,
+             pid_t *ptid, void *tls, pid_t *ctid); */
+ 
++.register %g2, #scratch
++.register %g3, #scratch
++
+ 	.text
+ ENTRY (__clone)