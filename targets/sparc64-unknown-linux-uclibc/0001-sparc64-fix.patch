--- a/packages/uClibc-ng/1.0.57/0001-sparc64-fix.patch
+++ b/packages/uClibc-ng/1.0.57/0001-sparc64-fix.patch
@@ -0,0 +1,24 @@
+--- a/libc/sysdeps/linux/sparc/clone.S  2026-03-01 00:49:31.000000000 -0500
++++ b/libc/sysdeps/linux/sparc/clone.S  2026-04-18 10:17:21.526044686 -0400
+@@ -19,6 +19,9 @@
+ /* clone() is even more special than fork() as it mucks with stacks
+    and invokes a function in the right context after its all over.  */
+
++.register %g2, #scratch
++.register %g3, #scratch
++
+ #include <asm/errno.h>
+ #include <asm/unistd.h>
+ #include <sysdep.h>
+@@ -26,6 +29,11 @@
+ /* int clone(int (*fn)(void *arg), void *child_stack, int flags, void *arg,
+             pid_t *ptid, void *tls, pid_t *ctid); */
+
++#if defined(__sparc_v9__) || defined(__arch64__)
++.register %g2, #scratch
++.register %g3, #scratch
++#endif
++
+        .text
+ ENTRY (__clone)
+        save    %sp,-96,%sp
